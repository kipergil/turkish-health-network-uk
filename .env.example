# Canonical site URL used for metadata, sitemap and OpenGraph. Set this to your
# deployment's real domain before going to production.
NEXT_PUBLIC_SITE_URL=https://www.turkishhealthnetwork.uk

# Directus backend. DIRECTUS_TOKEN should be a static admin/service token used
# server-side only (never exposed to the client) for schema management,
# seeding, and privileged reads/writes.
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=

# Clerk authentication. The publishable key is safe to expose to the client;
# the secret key and webhook signing secret must stay server-only.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Signing secret for the /api/webhooks/clerk endpoint (from the Clerk Dashboard
# webhook's "Signing Secret"). Accepts either name for compatibility.
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_WEBHOOK_SECRET=
